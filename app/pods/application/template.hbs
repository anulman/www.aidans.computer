<div class={{routeStyleNamespaceClassSet}}>
  <canvas />
  {{!glitchy-canvas}}

  <header class='sticky-top bg-primary'>
    {{#nav-header class='container' dropdownComponent='nav-header/dropdown' as |nav|}}
      {{#nav.item}}
        {{nav.link-to 'Home' 'home' current-when=false}}
      {{/nav.item}}

      {{#each navCollections as |collection|}}
        {{#nav.dropdown tagName='li' as |dd|}}
          {{#dd.toggle}}
            {{link-to collection.name 'content.collection' collection.model}}
          {{/dd.toggle}}

          {{#dd.menu as |child|}}
            {{#each collection.model.items as |item|}}
              {{#child.item}}
                {{#child.link-to 'content.item' item}}
                  {{item.yaml.title}}
                {{/child.link-to}}
              {{/child.item}}
            {{/each}}
          {{/dd.menu}}
        {{/nav.dropdown}}
      {{/each}}
    {{/nav-header}}
  </header>

  <main class='container'>
    {{outlet}}
  </main>

  <footer class='bg-dark text-white'>
    <ul class='container list-unstyled d-flex align-items-center mb-2 mt-2'>
      <li class='mr-1'>copyright {{thisYear}} aidan nulman.</li>
      <li>photo by <a href='http://evablue.com'>eva blue</a>.</li>
    </ul>
  </footer>
</div>
